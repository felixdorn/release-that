{
    "name": "privagon/release-it",
    "description": "Automated release system for cool kids.",
    "keywords": ["release", "automated", "ci", "cd", "release-it"],
    "type": "project",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Félix Dorn",
            "email": "github@felixdorn.fr"
        }
    ],
    "require": {
        "php": "^7.4",
        "cypresslab/gitelephant": "^4.0",
        "laravel-zero/framework": "^6.0",
        "nette/schema": "^1.0",
        "phlak/semver": "^3.0",
        "suin/json": "^1.2"
    },
    "require-dev": {
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php application app:rename"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": ["builds/release-that"]
}
